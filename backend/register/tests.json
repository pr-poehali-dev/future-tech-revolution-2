{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing fields",
      "method": "POST",
      "path": "/",
      "body": {"email": "", "password": "", "username": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Invalid email",
      "method": "POST",
      "path": "/",
      "body": {"email": "notanemail", "password": "123456", "username": "test"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Short password",
      "method": "POST",
      "path": "/",
      "body": {"email": "test@test.com", "password": "123", "username": "test"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}
